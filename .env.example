# Copy to .env.local for local dev. Never commit real values.

# Stable deployment / tenant identifier. If unset, one is generated at first boot.
TENANT_ID=

# Signed-cookie session secret. Any non-empty string works for the event.
# If unset, an ephemeral one is generated at boot (sessions won't survive restart).
SESSION_SECRET=

# Admin/judge token protecting /api/_admin/* and /_admin.
# Default fallback is "letmein" if unset — change per deployment.
ADMIN_TOKEN=letmein

# Gate open time (ISO 8601). Before this time, middleware serves a
# splash page for browsers and a 503 JSON for /api/*. After, the real
# app passes through normally.
#
# Default in middleware.ts is 2026-04-09T17:55:00-07:00 (5 min safety
# margin before the nominal 18:00 PDT kickoff). Set this to a past
# timestamp (e.g. 2000-01-01T00:00:00Z) to bypass the gate for local
# development and functional tests.
EVENT_START_ISO=
